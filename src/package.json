{
  "name": "homeassistant-streamdeck",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:plugin && npm run build:ui",
    "build:plugin": "rollup -c",
    "build:ui": "esbuild ui-src/propertyInspector/main.ts ui-src/propertyInspector/credentials/main.ts --bundle --format=esm --platform=browser --outdir=ca.barraco.carlo.homeassistant.sdPlugin/ui/js --sourcemap",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart ca.barraco.carlo.homeassistant\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.3",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.2.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@tsconfig/node20": "^20.1.2",
    "@types/node": "~20.15.0",
    "@types/ws": "^8.5.10",
    "rollup": "^4.0.2",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2",
    "esbuild": "^0.21.5"
  }
}

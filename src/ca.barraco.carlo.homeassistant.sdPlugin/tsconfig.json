{
  "compilerOptions": {
    "target": "ES2019",
        "module": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "ES2019"],
    "moduleResolution": "NodeNext",
    "rootDir": "./",
    "outDir": "./dist/dev"
  },
  "include": ["lib/**/*.ts", "plugin/**/*.ts", "pi/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules"]
}

